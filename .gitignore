# ===== FICHIERS SENSIBLES (NE JAMAIS PUBLIER) =====
.env
.env.backup
*.key
storage/oauth-private.key
storage/oauth-public.key
storage/logs/*.log

# ===== DOSSIERS GÉNÉRÉS / CACHE =====
/vendor
/node_modules
public/storage
public/hot
bootstrap/cache/*
!.gitkeep
storage/framework/cache/*
storage/framework/sessions/*
storage/framework/views/*
storage/app/public/*

# ===== FICHIERS SYSTÈME / IDE =====
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ===== MODÈLES IA LOCAUX (OLLAMA) =====
